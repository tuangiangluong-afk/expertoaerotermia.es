{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "nextjs",
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
        {
            "source": "/:path((?!api/).*)",
            "has": [
                {
                    "type": "host",
                    "value": "www.expertpompeachaleur.com"
                }
            ],
            "destination": "https://expertpompeachaleur.com/:path",
            "statusCode": 301
        }
    ],
    "crons": [
        {
            "path": "/api/indexnow",
            "schedule": "0 0 * * *"
        }
    ]
}